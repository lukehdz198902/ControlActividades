@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Control de Actividades</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="@Url.Content("~/Content/style.css")" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
</head>
<body>
    <div id="loginView">
        <canvas id="particleCanvas"></canvas>
        <div class="login-container">
            <div class="login-card">
                <div class="login-header">
                    <div class="login-icon">📋</div>
                    <h1>Control de Actividades</h1>
                    <p>Ingresa tus credenciales para continuar</p>
                </div>
                <form id="loginForm" method="post" action="/Account/Login">
                    <div class="form-group">
                        <label for="loginUsername">Usuario</label>
                        <input type="text" id="loginUsername" name="username" placeholder="Nombre de usuario" autocomplete="username">
                    </div>
                    <div class="form-group">
                        <label for="loginPassword">Contraseña</label>
                        <input type="password" id="loginPassword" name="password" placeholder="Contraseña" autocomplete="current-password">
                    </div>
                    <div id="loginError" class="form-error">@ViewBag.Error</div>
                    <button type="submit" class="btn btn-primary btn-full">Iniciar Sesión</button>
                </form>
                <div class="login-footer">
                    <p>Usuarios: lhernanb, dgarcia, creyesg, JCABELLS, OQUINTAA</p>
                </div>
            </div>
        </div>
    </div>

    <div id="appView" style="display:none">
        <header class="navbar">
            <div class="nav-brand">
                <span class="nav-logo">📋</span>
                <span class="nav-title">Control de Actividades</span>
            </div>
            <div class="nav-user">
                <span class="user-greeting">👋 <span id="currentUserDisplay"></span></span>
                <button id="logoutBtn" class="btn btn-ghost">Cerrar Sesión</button>
            </div>
        </header>

        <div class="app-layout">
            <aside class="sidebar">
                <nav class="sidebar-nav">
                    <a href="#" class="nav-item active" data-section="dashboard">
                        <span class="nav-icon">📊</span>
                        <span class="nav-label">Dashboard</span>
                    </a>
                    <a href="#" class="nav-item" data-section="new-project">
                        <span class="nav-icon">➕</span>
                        <span class="nav-label">Nuevo Proyecto</span>
                    </a>
                </nav>
                <div class="sidebar-divider" id="adminDivider" style="display:none"></div>
                <div class="sidebar-section" id="adminNavSection" style="display:none">
                    <h3 class="sidebar-section-title">Administración</h3>
                    <nav class="sidebar-nav">
                        <a href="#" class="nav-item" data-section="admin-users">
                            <span class="nav-icon">👥</span>
                            <span class="nav-label">Usuarios</span>
                        </a>
                        <a href="#" class="nav-item" data-section="admin-dashboard">
                            <span class="nav-icon">📋</span>
                            <span class="nav-label">Dashboard Admin</span>
                        </a>
                    </nav>
                </div>
                <div class="sidebar-divider"></div>
                <div class="sidebar-section">
                    <h3 class="sidebar-section-title">Mis Proyectos</h3>
                    <div id="sidebarProjects" class="sidebar-project-list"></div>
                </div>
            </aside>

            <main class="content">
                <section id="dashboardSection" class="content-section active">
                    <div class="section-header">
                        <h2>Dashboard</h2>
                    </div>
                    <div class="filter-bar">
                        <div class="filter-group">
                            <label>Mes</label>
                            <select id="filterMonth"></select>
                        </div>
                        <div class="filter-group">
                            <label>Año</label>
                            <select id="filterYear"></select>
                        </div>
                        <button id="filterBtn" class="btn btn-primary">Filtrar</button>
                    </div>
                    <div class="chart-container"><canvas id="dashboardChart"></canvas></div>
                    <div id="dashboardContent"></div>
                </section>

                <section id="newProjectSection" class="content-section">
                    <div class="section-header">
                        <h2>Nuevo Proyecto</h2>
                    </div>
                    <div class="card">
                        <form id="projectForm">
                            <div class="form-group">
                                <label for="projectName">Nombre del Proyecto</label>
                                <input type="text" id="projectName" placeholder="Ej: Desarrollo Web, Diseño UX, etc.">
                                <div id="projectError" class="form-error"></div>
                            </div>
                            <button type="submit" class="btn btn-primary">Crear Proyecto</button>
                        </form>
                    </div>
                </section>

                <section id="projectDetailSection" class="content-section">
                    <div class="section-header">
                        <button id="backToDashboard" class="btn btn-ghost">← Volver al Dashboard</button>
                        <h2 id="projectDetailTitle"></h2>
                    </div>

                    <div class="card">
                        <h3 class="card-title">Registrar Actividad</h3>
                        <form id="activityForm">
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="activityDate">Fecha</label>
                                    <input type="date" id="activityDate">
                                </div>
                                <div class="form-group">
                                    <label for="activityImportance">Importancia</label>
                                    <select id="activityImportance">
                                        <option value="Alta">🔴 Alta</option>
                                        <option value="Media" selected>🟡 Media</option>
                                        <option value="Baja">🟢 Baja</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="activityDesc">Descripción</label>
                                <textarea id="activityDesc" rows="2" placeholder="Describe la actividad realizada..."></textarea>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="activityHours">Horas</label>
                                    <input type="number" id="activityHours" min="0" max="23" value="0">
                                </div>
                                <div class="form-group">
                                    <label for="activityMinutes">Minutos</label>
                                    <select id="activityMinutes">
                                        <option value="0">0</option>
                                        <option value="15">15</option>
                                        <option value="30" selected>30</option>
                                        <option value="45">45</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Icono</label>
                                <div id="iconPicker" class="icon-picker"></div>
                            </div>
                            <div id="activityError" class="form-error"></div>
                            <button type="submit" class="btn btn-primary">Guardar Actividad</button>
                        </form>
                    </div>

                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Actividades Registradas</h3>
                            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                                <button id="exportCsvBtn" class="btn btn-ghost">📥 CSV</button>
                            </div>
                        </div>
                        <div class="report-filter">
                            <div class="filter-group">
                                <label>Mes</label>
                                <select id="reportMonth"></select>
                            </div>
                            <div class="filter-group">
                                <label>Año</label>
                                <select id="reportYear"></select>
                            </div>
                        </div>
                        <div id="activityListContent"></div>
                    </div>
                </section>

                <section id="adminUsersSection" class="content-section">
                    <div class="section-header">
                        <h2>Administrar Usuarios</h2>
                    </div>
                    <div class="card">
                        <h3 class="card-title">Registrar Nuevo Usuario</h3>
                        <form id="adminUserForm">
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="adminNewUsername">Usuario</label>
                                    <input type="text" id="adminNewUsername" placeholder="Nombre de usuario">
                                </div>
                                <div class="form-group">
                                    <label for="adminNewRole">Rol</label>
                                    <select id="adminNewRole">
                                        <option value="user">Usuario</option>
                                        <option value="admin">Administrador</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="adminNewPassword">Contraseña</label>
                                    <input type="password" id="adminNewPassword" placeholder="Contraseña">
                                </div>
                                <div class="form-group">
                                    <label for="adminNewPasswordConfirm">Confirmar Contraseña</label>
                                    <input type="password" id="adminNewPasswordConfirm" placeholder="Repetir contraseña">
                                </div>
                            </div>
                            <div id="adminUserError" class="form-error"></div>
                            <button type="submit" class="btn btn-primary">Crear Usuario</button>
                        </form>
                    </div>
                    <div class="card">
                        <h3 class="card-title">Usuarios Registrados</h3>
                        <div id="adminUsersList"></div>
                    </div>
                </section>

                <section id="adminDashboardSection" class="content-section">
                    <div class="section-header">
                        <h2>Dashboard de Administración</h2>
                    </div>
                    <div class="filter-bar">
                        <div class="filter-group">
                            <label>Mes</label>
                            <select id="adminFilterMonth"></select>
                        </div>
                        <div class="filter-group">
                            <label>Año</label>
                            <select id="adminFilterYear"></select>
                        </div>
                        <button id="adminFilterBtn" class="btn btn-primary">Filtrar</button>
                    </div>
                    <div class="chart-container"><canvas id="adminDashboardChart"></canvas></div>
                    <div id="adminDashboardContent"></div>
                </section>

                <section id="adminUserActivitiesSection" class="content-section">
                    <div class="section-header">
                        <button id="backToAdminDashboard" class="btn btn-ghost">← Volver</button>
                        <h2 id="adminUserActivitiesTitle">Actividades del Usuario</h2>
                    </div>
                    <div id="adminUserActivitiesContent"></div>
                </section>
            </main>
        </div>
    </div>

    <div id="passwordModal" class="modal-overlay" style="display:none">
        <div class="modal-card">
            <div class="modal-header">
                <h3>Cambiar Contraseña</h3>
                <button type="button" class="modal-close" id="passwordModalClose">&times;</button>
            </div>
            <div class="modal-body">
                <p id="passwordModalUser" style="margin-bottom:16px;color:var(--text-secondary);font-size:14px;"></p>
                <form id="passwordModalForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="pwdModalNewPassword">Nueva Contraseña</label>
                            <input type="password" id="pwdModalNewPassword" placeholder="Nueva contraseña">
                        </div>
                        <div class="form-group">
                            <label for="pwdModalConfirmPassword">Confirmar Contraseña</label>
                            <input type="password" id="pwdModalConfirmPassword" placeholder="Repetir contraseña">
                        </div>
                    </div>
                    <div id="pwdModalError" class="form-error"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" id="passwordModalCancel">Cancelar</button>
                <button type="button" class="btn btn-primary" id="passwordModalSave">Guardar</button>
            </div>
        </div>
    </div>
    <div id="editUserModal" class="modal-overlay" style="display:none">
        <div class="modal-card">
            <div class="modal-header">
                <h3>Editar Usuario</h3>
                <button type="button" class="modal-close" id="editUserModalClose">&times;</button>
            </div>
            <div class="modal-body">
                <form id="editUserForm">
                    <div class="form-group">
                        <label for="editUsername">Nombre de Usuario</label>
                        <input type="text" id="editUsername" placeholder="Usuario">
                    </div>
                    <div class="form-group">
                        <label for="editRole">Rol</label>
                        <select id="editRole">
                            <option value="user">Usuario</option>
                            <option value="admin">Administrador</option>
                        </select>
                    </div>
                    <div id="editUserError" class="form-error"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" id="editUserModalCancel">Cancelar</button>
                <button type="button" class="btn btn-primary" id="editUserModalSave">Guardar</button>
            </div>
        </div>
    </div>
    <div id="toast" class="toast"></div>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="@Url.Content("~/Scripts/app.js")"></script>
</body>
</html>
